+import { FastifyPluginAsync } from 'fastify';
+import { authMiddleware } from '../../middlewares/auth';
+import { z } from 'zod';
+
+const router: FastifyPluginAsync = async (fastify) => {
+  const initSchema = z.object({ key: z.string().optional(), contentType: z.string().optional() });
+  const ALLOWED = ['video/mp4', 'image/jpeg', 'image/png', 'application/octet-stream'];
+
+  fastify.post('/init', { preHandler: [authMiddleware, (fastify as any).validate(initSchema)] }, async (request, reply) => {
+    const { contentType } = (request.body as any) || {};
+    const userId = (request as any).user?.id;
+    if (!userId) return reply.status(401).send({ error: 'Unauthorized' });
+
+    if (contentType && !ALLOWED.includes(contentType)) return reply.status(400).send({ error: 'Invalid contentType' });
+
+    const ext = contentType === 'video/mp4' ? '.mp4' : contentType === 'image/jpeg' ? '.jpg' : contentType === 'image/png' ? '.png' : '.bin';
+    const uploadKey = `uploads/${userId}/${Date.now()}-${Math.random().toString(36).slice(2)}${ext}`;
+
+    const presigned = await import('../../uploads/r2').then((m) => m.generatePresignedUpload(uploadKey, contentType));
+    return presigned;
+  });
+
+  fastify.post('/complete', { preHandler: authMiddleware }, async (request, reply) => {
+    return { ok: true };
+  });
+};
+
+export default router;
