+import { describe, it, expect } from 'vitest';
+import Fastify from 'fastify';
+import { registerRoutes } from '../../app/routes';
+
+describe('auth register', () => {
+  it('rejects missing password', async () => {
+    const server = Fastify();
+    await registerRoutes(server);
+    const res = await server.inject({
+      method: 'POST',
+      url: '/auth/register',
+      payload: { username: 'u'+Date.now(), email: `t${Date.now()}@example.com` }
+    });
+    expect(res.statusCode).toBe(400);
+  });
+
+  it('rejects short password', async () => {
+    const server = Fastify();
+    await registerRoutes(server);
+    const res = await server.inject({
+      method: 'POST',
+      url: '/auth/register',
+      payload: { username: 'u'+Date.now(), email: `t${Date.now()}@example.com`, password: '123' }
+    });
+    expect(res.statusCode).toBe(400);
+  });
+
+  it('registers with strong password', async () => {
+    const server = Fastify();
+    await registerRoutes(server);
+    const res = await server.inject({
+      method: 'POST',
+      url: '/auth/register',
+      payload: { username: 'u'+Date.now(), email: `t${Date.now()}@example.com`, password: 'Password123!' }
+    });
+    expect([200,201]).toContain(res.statusCode);
+    if (res.statusCode === 200) {
+      const body = JSON.parse(res.payload);
+      expect(body.token).toBeDefined();
+      expect(body.user).toBeDefined();
+    }
+  });
+});

