# URL pública del backend (HTTP + Socket.IO). Se "hornea" en el build de Vite.
#
# PRODUCCIÓN (Render): definí la URL pública del API, ej.
#   VITE_API_URL=https://cinecito-api.onrender.com
#
# LOCAL / LAN multidispositivo: dejala VACÍA o comentada. La web usará el mismo
# host desde el que se abre (la IP de la PC en el celular/tablet), sin hardcodear.
# Definila solo si querés apuntar a un backend en otro host/puerto.
VITE_API_URL=http://localhost:4000

# ── TURN (opcional, recomendado para que la llamada conecte en redes difíciles) ──
# Sin TURN, las llamadas detrás de NAT estricto/simétrico (algunos móviles, redes
# corporativas) NO conectan. Conseguí credenciales en metered.ca, Twilio o un coturn
# propio y definí estas 3 (se hornean en el build de Vite). Acepta varias URLs por coma.
#   VITE_TURN_URL=turn:tu-servidor:3478
#   VITE_TURN_USERNAME=usuario
#   VITE_TURN_CREDENTIAL=clave

# ── Sentry (opcional) — monitoreo de errores del frontend ─────────────────────
# Si se define, Sentry se inicializa SOLO en producción (carga dinámica → cero peso
# si no está). Creá un proyecto en sentry.io y pegá el DSN del proyecto "browser".
#   VITE_SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/XXXX
