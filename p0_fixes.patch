+import { describe, it, expect } from 'vitest';
+import Fastify from 'fastify';
+import { registerRoutes } from '../app/routes';
+
+describe('uploads security', () => {
+  it('POST /uploads/init requires auth and returns key prefix', async () => {
+    const server = Fastify();
+    await registerRoutes(server);
+
+    const reg = await server.inject({ method: 'POST', url: '/auth/register', payload: { username: 'u'+Date.now(), email: `u${Date.now()}@example.com`, password: 'Password123!' } });
+    const user = JSON.parse(reg.payload);
+
+    // unauthenticated
+    const anon = await server.inject({ method: 'POST', url: '/uploads/init', payload: { contentType: 'video/mp4' } });
+    expect([401,403]).toContain(anon.statusCode);
+
+    // authenticated and allowed contentType
+    const ok = await server.inject({ method: 'POST', url: '/uploads/init', payload: { contentType: 'video/mp4' }, headers: { Authorization: `Bearer ${user.token}` } });
+    expect([200,201]).toContain(ok.statusCode);
+    if (ok.statusCode === 200) {
+      const body = JSON.parse(ok.payload);
+      expect(body.key.startsWith(`uploads/`)).toBeTruthy();
+      expect(body.uploadUrl).toBeDefined();
+    }
+
+    // forbidden content type
+    const bad = await server.inject({ method: 'POST', url: '/uploads/init', payload: { contentType: 'text/plain' }, headers: { Authorization: `Bearer ${user.token}` } });
+    expect(bad.statusCode).toBe(400);
+  });
+});
