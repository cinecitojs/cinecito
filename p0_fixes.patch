+import { FastifyPluginAsync } from 'fastify';
+import { prisma } from '../../lib/db';
+import { authMiddleware } from '../../middlewares/auth';
+import { z } from 'zod';
+
+const router: FastifyPluginAsync = async (fastify) => {
+  const createRoomSchema = z.object({ name: z.string().min(1), isPrivate: z.boolean().optional() });
+  const joinRoomSchema = z.object({ code: z.string().min(1), displayName: z.string().min(1) });
+  const transferHostSchema = z.object({ roomId: z.string().min(1), newOwnerId: z.string().min(1) });
+
+  // Create room: authenticated, owner derived from token
+  fastify.post('/', { preHandler: [authMiddleware, (fastify as any).validate(createRoomSchema)] }, async (request, reply) => {
+    const { name, isPrivate } = request.body as any;
+    const code = Math.random().toString(36).substring(2, 8).toUpperCase();
+    const ownerId = (request as any).user?.id;
+    if (!ownerId) return reply.status(401).send({ error: 'Unauthorized' });
+    const data: any = { name, code, isPrivate: !!isPrivate, ownerId };
+    const room = await prisma.room.create({ data });
+    reply.send(room);
+  });
+
+  // Join room: validate input; require auth for private rooms (server-side enforcement)
+  fastify.post('/join', { preHandler: (fastify as any).validate(joinRoomSchema) }, async (request, reply) => {
+    const { code, displayName } = request.body as any;
+    const room = await prisma.room.findUnique({ where: { code } });
+    if (!room) return reply.status(404).send({ error: 'Room not found' });
+
+    if (room.isPrivate) {
+      // require auth for private rooms
+      const authHeader = request.headers.authorization;
+      if (!authHeader) return reply.status(403).send({ error: 'Private room, authentication required' });
+      await authMiddleware(request as any, reply as any);
+      if ((reply as any).sent) return;
+    }
+
+    const userId = (request as any).user?.id || null;
+    const member = await prisma.roomMember.create({ data: { roomId: room.id, displayName, userId } });
+    reply.send({ room, member });
+  });
+
+  // Get room: include members only for authorized users on private rooms
+  fastify.get('/:id', async (request, reply) => {
+    const { id } = request.params as any;
+    const room = await prisma.room.findUnique({ where: { id }, include: { members: true } });
+    if (!room) return reply.status(404).send({ error: 'Not found' });
+    if (room.isPrivate) {
+      const authHeader = request.headers.authorization;
+      if (!authHeader) return reply.status(403).send({ error: 'Forbidden' });
+      await authMiddleware(request as any, reply as any);
+      if ((reply as any).sent) return;
+      const userId = (request as any).user?.id;
+      const isMember = room.members.some((m) => m.userId === userId);
+      if (!isMember && room.ownerId !== userId) {
+        return reply.status(403).send({ error: 'Forbidden' });
+      }
+    }
+    reply.send(room);
+  });
+
+  // Delete room: require auth and ownership or admin
+  fastify.delete('/:id', { preHandler: authMiddleware }, async (request, reply) => {
+    const { id } = request.params as any;
+    const userId = (request as any).user?.id;
+    const room = await prisma.room.findUnique({ where: { id } });
+    if (!room) return reply.status(404).send({ error: 'Not found' });
+    if (room.ownerId !== userId) {
+      // check DB role for admin privilege
+      const user = await prisma.user.findUnique({ where: { id: userId }, select: { role: true } });
+      if (user?.role !== 'ADMIN') return reply.status(403).send({ error: 'Forbidden' });
+    }
+    await prisma.room.delete({ where: { id } });
+    reply.send({ ok: true });
+  });
+
+  // Transfer host: require auth and ownership or admin
+  fastify.post('/transfer-host', { preHandler: [authMiddleware, (fastify as any).validate(transferHostSchema)] }, async (request, reply) => {
+    const { roomId, newOwnerId } = request.body as any;
+    const userId = (request as any).user?.id;
+    const room = await prisma.room.findUnique({ where: { id: roomId } });
+    if (!room) return reply.status(404).send({ error: 'Not found' });
+    if (room.ownerId !== userId) {
+      const user = await prisma.user.findUnique({ where: { id: userId }, select: { role: true } });
+      if (user?.role !== 'ADMIN') return reply.status(403).send({ error: 'Forbidden' });
+    }
+    await prisma.room.update({ where: { id: roomId }, data: { ownerId: newOwnerId } });
+    reply.send({ ok: true });
+  });
+};
+
+export default router;
