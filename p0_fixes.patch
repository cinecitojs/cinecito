+import { describe, it, expect } from 'vitest';
+import Fastify from 'fastify';
+import { registerRoutes } from '../../app/routes';
+
+describe('rooms auth & ownership', () => {
+  it('POST /rooms requires auth', async () => {
+    const server = Fastify();
+    await registerRoutes(server);
+    const res = await server.inject({ method: 'POST', url: '/rooms', payload: { name: 'r' } });
+    expect(res.statusCode).toBe(401);
+  });
+
+  it('POST /rooms sets owner from token and DELETE requires owner', async () => {
+    const server = Fastify();
+    await registerRoutes(server);
+
+    // register owner
+    const reg = await server.inject({ method: 'POST', url: '/auth/register', payload: { username: 'owner'+Date.now(), email: `owner${Date.now()}@example.com`, password: 'Password123!' } });
+    const owner = JSON.parse(reg.payload);
+    const tokenOwner = owner.token;
+
+    // create room as owner
+    const r = await server.inject({ method: 'POST', url: '/rooms', payload: { name: 'roomA' }, headers: { Authorization: `Bearer ${tokenOwner}` } });
+    expect([200,201]).toContain(r.statusCode);
+    const room = JSON.parse(r.payload);
+
+    // register attacker
+    const reg2 = await server.inject({ method: 'POST', url: '/auth/register', payload: { username: 'att'+Date.now(), email: `att${Date.now()}@example.com`, password: 'Password123!' } });
+    const attacker = JSON.parse(reg2.payload);
+    const tokenAtt = attacker.token;
+
+    // attacker tries to delete
+    const delAtt = await server.inject({ method: 'DELETE', url: `/rooms/${room.id}`, headers: { Authorization: `Bearer ${tokenAtt}` } });
+    expect([401,403]).toContain(delAtt.statusCode);
+
+    // owner deletes
+    const delOwner = await server.inject({ method: 'DELETE', url: `/rooms/${room.id}`, headers: { Authorization: `Bearer ${tokenOwner}` } });
+    expect([200,201]).toContain(delOwner.statusCode);
+  });
+
+  it('transfer-host requires owner (or admin)', async () => {
+    const server = Fastify();
+    await registerRoutes(server);
+
+    const reg = await server.inject({ method: 'POST', url: '/auth/register', payload: { username: 'owner'+Date.now(), email: `owner${Date.now()}@example.com`, password: 'Password123!' } });
+    const owner = JSON.parse(reg.payload);
+    const tokenOwner = owner.token;
+
+    const reg2 = await server.inject({ method: 'POST', url: '/auth/register', payload: { username: 'user2'+Date.now(), email: `u2${Date.now()}@example.com`, password: 'Password123!' } });
+    const user2 = JSON.parse(reg2.payload);
+
+    const r = await server.inject({ method: 'POST', url: '/rooms', payload: { name: 'roomB' }, headers: { Authorization: `Bearer ${tokenOwner}` } });
+    const room = JSON.parse(r.payload);
+
+    // attacker (user2) tries transfer
+    const transferAtt = await server.inject({ method: 'POST', url: '/rooms/transfer-host', payload: { roomId: room.id, newOwnerId: user2.user.id }, headers: { Authorization: `Bearer ${user2.token}` } });
+    expect([401,403]).toContain(transferAtt.statusCode);
