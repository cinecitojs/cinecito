+import { FastifyPluginAsync } from 'fastify';
+import { prisma } from '../../lib/db';
+import { authMiddleware } from '../../middlewares/auth';
+import { z } from 'zod';
+
+const router: FastifyPluginAsync = async (fastify) => {
+  const createMessageSchema = z.object({ roomId: z.string().min(1), content: z.string().min(1) });
+
+  fastify.post('/', { preHandler: [authMiddleware, (fastify as any).validate(createMessageSchema)] }, async (request, reply) => {
+    const { roomId, content } = request.body as any;
+    const userId = (request as any).user?.id;
+    if (!userId) return reply.status(401).send({ error: 'Unauthorized' });
+
+    const room = await prisma.room.findUnique({ where: { id: roomId } });
+    if (!room) return reply.status(404).send({ error: 'Room not found' });
+    if (room.isPrivate) {
+      const isMember = await prisma.roomMember.findFirst({ where: { roomId, userId } });
+      if (!isMember && room.ownerId !== userId) return reply.status(403).send({ error: 'Forbidden' });
+    }
+
+    const msg = await prisma.message.create({ data: { roomId, userId, content } });
+    fastify.io?.to(roomId).emit('message', msg);
+    return reply.send(msg);
+  });
+
+  fastify.get('/', { preHandler: authMiddleware }, async (request, reply) => {
+    const { roomId, page = '1', limit = '50' } = request.query as any;
+    if (!roomId) return reply.status(400).send({ error: 'roomId required' });
+    const userId = (request as any).user?.id;
+    const room = await prisma.room.findUnique({ where: { id: roomId } });
+    if (!room) return reply.status(404).send({ error: 'Not found' });
+    if (room.isPrivate) {
+      const isMember = await prisma.roomMember.findFirst({ where: { roomId, userId } });
+      if (!isMember && room.ownerId !== userId) return reply.status(403).send({ error: 'Forbidden' });
+    }
+    const p = Math.max(1, parseInt(page, 10) || 1);
+    const l = Math.min(200, parseInt(limit, 10) || 50);
+    const messages = await prisma.message.findMany({
+      where: { roomId },
+      orderBy: { createdAt: 'desc' },
+      take: l,
+      skip: (p - 1) * l,
+    });
+    return reply.send({ messages, page: p, limit: l });
+  });
+};
+
+export default router;
