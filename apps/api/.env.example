# ── Base de datos ─────────────────────────────────────────────
# Genérico:
DATABASE_URL=postgresql://user:pass@localhost:5432/cinecito?schema=public
#
# SUPABASE: usá el POOLER de sesión (Supavisor), NO el host directo.
# El host directo db.<ref>.supabase.co es IPv6-only y tira P1001 cuando el
# enlace pierde IPv6. El pooler tiene IPv4 y es estable.
# Dashboard → Project Settings → Database → Connection string → "Session pooler".
# Formato:
#   postgresql://postgres.<ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# ── JWT — mínimo 32 caracteres aleatorios ─────────────────────
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_32_caracteres_minimo

# ── Redis (Upstash, Railway) — opcional en desarrollo ─────────
REDIS_URL=redis://localhost:6379

# ── Cloudflare R2 (para subida de videos) ─────────────────────
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=cinecito-videos
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# ── Entorno ───────────────────────────────────────────────────
# development (default) | production | test.
# En production: CORS se restringe a FRONTEND_URL (obligatorio) y Prisma usa una sola instancia.
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────
# Origen EXACTO del frontend (sin barra final). En producción es OBLIGATORIO:
# si falta, el server no arranca (evita una web rota por CORS en silencio).
# Prod ej.: https://cinecito-web.onrender.com
FRONTEND_URL=http://localhost:5173

# ── Servidor ──────────────────────────────────────────────────
# En Render NO definas PORT: la plataforma lo inyecta. En local, 4000.
PORT=4000

# Detrás de proxy (Render, nginx, Cloudflare) → 'true' para obtener la IP real
# del cliente (necesario para el rate-limit por IP). En local dejar en false/vacío.
TRUST_PROXY=false

# ── Panel de administración ───────────────────────────────────
# Correos (separados por coma) que se auto-promueven a ADMIN al iniciar sesión.
ADMIN_EMAILS=

# ── Apoyo voluntario / pagos (opcional) ───────────────────────
# Ko-fi: panel → More → Webhooks → "Verification Token". Habilita la entrega
# automática de recompensas al confirmarse el aporte.
KOFI_VERIFICATION_TOKEN=
# Alternativas de pago (verificación de firma de webhook):
STRIPE_WEBHOOK_SECRET=
MP_WEBHOOK_SECRET=
# 'true' permite conceder tiers SIN pago (solo para probar; NO usar en producción):
SUPPORT_DEV_GRANT=
# URL(s) de checkout externas si se usan (sin webhook): general y/o por tier:
SUPPORT_CHECKOUT_URL=

# ── Opcional ──────────────────────────────────────────────────
SENTRY_DSN=
# Si se define, GET /metrics exige `Authorization: Bearer <token>`:
METRICS_BEARER_TOKEN=

# ── TURN server (opcional, para Fase 4 — llamadas de voz) ─────
# Solo necesario si los participantes están detrás de NAT estricto.
# Servicios gratuitos: Metered.ca, o montar Coturn.
# Si se deja vacío, se usa solo STUN (funciona en la mayoría de redes).
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
