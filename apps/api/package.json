{
  "name": "cinecito-api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "cleanup:guests": "ts-node src/jobs/cleanupGuests.cli.ts",
    "make-admin": "ts-node src/jobs/makeAdmin.cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.345.0",
    "@aws-sdk/s3-request-presigner": "^3.345.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^8.0.0",
    "@fastify/sensible": "^5.6.0",
    "@prisma/client": "^5.10.0",
    "@sentry/node": "^7.0.0",
    "@socket.io/redis-adapter": "^8.1.0",
    "bcrypt": "^5.1.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.29.1",
    "fastify-plugin": "^4.5.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.0",
    "pino": "^8.14.0",
    "prom-client": "^14.0.0",
    "socket.io": "^4.8.3",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.11.24",
    "pino-pretty": "^9.1.0",
    "prettier": "^3.0.0",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  }
}
