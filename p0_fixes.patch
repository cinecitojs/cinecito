+import { describe, it, expect } from 'vitest';
+import Fastify from 'fastify';
+import { registerRoutes } from '../app/routes';
+
+describe('messages access control', () => {
+  it('GET /messages requires membership for private rooms', async () => {
+    const server = Fastify();
+    await registerRoutes(server);
+
+    const reg = await server.inject({ method: 'POST', url: '/auth/register', payload: { username: 'owner'+Date.now(), email: `owner${Date.now()}@example.com`, password: 'Password123!' } });
+    const owner = JSON.parse(reg.payload);
+
+    const r = await server.inject({ method: 'POST', url: '/rooms', payload: { name: 'privateRoom', isPrivate: true }, headers: { Authorization: `Bearer ${owner.token}` } });
+    const room = JSON.parse(r.payload);
+
+    // unauthenticated list
+    const listAnon = await server.inject({ method: 'GET', url: `/messages?roomId=${room.id}` });
+    expect([401,403]).toContain(listAnon.statusCode);
+
+    // owner posts message
+    const post = await server.inject({ method: 'POST', url: '/messages', payload: { roomId: room.id, content: 'hi' }, headers: { Authorization: `Bearer ${owner.token}` } });
+    expect([200,201]).toContain(post.statusCode);
+
+    // owner lists messages
+    const listOwner = await server.inject({ method: 'GET', url: `/messages?roomId=${room.id}`, headers: { Authorization: `Bearer ${owner.token}` } });
+    expect([200,201]).toContain(listOwner.statusCode);
+    if (listOwner.statusCode === 200) {
+      const body = JSON.parse(listOwner.payload);
+      expect(Array.isArray(body.messages)).toBe(true);
+    }
+  });
+});

